# Backend environment. Copy to backend/.env and fill in.

PORT=3001
# CORS origin for the dev frontend; unset = same-origin only.
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
# Max downloads allowed to run at once. A POST /api/download over this cap gets
# HTTP 429. Unset or invalid falls back to 3.
MAX_CONCURRENT_DOWNLOADS=3

# --- Cloud upload ("Move to Dropbox") -------------------------------------
# See docs/dropbox-setup.md for how to obtain these. The feature is disabled
# unless all three are set. The app SECRET must exist only on the backend.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:5173/oauth/callback
# App-folder name under /Apps/<name>/, used only for the "Open in Dropbox" link.
DROPBOX_APP_FOLDER=Tubekeep
