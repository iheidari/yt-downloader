# Backend environment. Copy to backend/.env and fill in.

PORT=3001
# CORS origin for the dev frontend; unset = same-origin only. CORS credentials
# are enabled and pinned to this exact origin (never a wildcard).
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
# Where downloaded media + metadata.json live. Resolved to an absolute path at
# startup and logged once. Unset defaults to backend/downloads (inside the
# source tree, which nodemon.json separately guards against watching) — point
# this at a sibling path outside the package directory instead, e.g.
# ../.data/downloads, so linters/watchers/editor indexing never have to walk
# gigabytes of video.
# DOWNLOADS_DIR=../.data/downloads
# Max downloads allowed to run at once. A POST /api/download over this cap gets
# HTTP 429. Unset or invalid falls back to 3.
MAX_CONCURRENT_DOWNLOADS=3
# Overrides the boot-time IPv6 probe (services/ipv6.js) in either direction —
# leave unset for auto-detection. At boot, the server probes IPv6 reachability
# and forces --force-ipv4 on every yt-dlp call itself if a route is present but
# black-holed (a network that advertises an IPv6 default route while silently
# dropping IPv6 traffic makes every yt-dlp call stall ~85s instead of ~1.5s,
# waiting out the AAAA TCP timeout — Python's urllib has no Happy Eyeballs).
# Set this explicitly only if the probe's own verdict is wrong for your
# network: `true` forces IPv4 even though the probe read the route as fine;
# `false` leaves IPv4-forcing off even though the probe read it as
# black-holed. A genuinely IPv6-only host needs no override — the probe reads
# its real IPv6 connectivity as reachable and already leaves IPv4-forcing off
# on its own. Symptom of the original bug: /api/info spins for a minute-plus
# at near-zero CPU. Diagnose by hand with `curl -6 -m 5 https://www.youtube.com`
# (hangs) vs `curl -4` (fast).
# YTDLP_FORCE_IPV4=true

# --- Auth + database (magic-link login) -----------------------------------
# Neon Postgres connection string (keep sslmode=require). The server applies
# schema.sql itself on every boot when this is set (idempotent, self-healing);
# `npm run db:init` still works standalone to provision a fresh database by
# hand. Users are managed by hand in the Neon dashboard.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# TLS cert verification is ON by default. Set this to true ONLY if your database's
# CA isn't in Node's trust store (connection stays encrypted, just unverified).
# DATABASE_SSL_NO_VERIFY=true
# HMAC secret used to sign the session-cookie JWT. Generate a long random value,
# e.g. `openssl rand -base64 48`. Keep it secret; do not commit. REQUIRED in
# production — the server refuses to start without it.
JWT_SECRET=
# Base URL the emailed magic link points at, and the post-login redirect target.
APP_URL=http://localhost:3001
# Resend API key for sending the magic-link email. Leave UNSET in dev — the link
# is then logged to the server console instead of emailed, so login is testable
# without any mail credentials.
RESEND_API_KEY=
# Verified Resend sender address for the magic-link email.
EMAIL_FROM=Tubekeep <login@yourdomain>

# --- Cloud upload ("Move to cloud") ---------------------------------------
# Each provider is independent: configure any subset. A provider only appears in
# the "Move to cloud" menu when all of its required creds are set. Secrets must
# exist only on the backend.

# Dropbox — see docs/dropbox-setup.md. Requires all three.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:5173/oauth/callback
# App-folder name under /Apps/<name>/, used only for the "Open in Dropbox" link.
DROPBOX_APP_FOLDER=Tubekeep

# Google Drive — see docs/google-drive-setup.md. Requires all three. Uses the
# drive.file scope (app-created files only); uploads land in a "Tubekeep" folder.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback
# Destination folder name created/reused in the user's My Drive.
GOOGLE_DRIVE_FOLDER=Tubekeep
